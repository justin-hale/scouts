# URL of the deployed Cloudflare Worker that proxies reads/writes to the Gist.
# Leave BLANK for local development — the app then falls back to in-browser
# localStorage with the bundled sample data, so editing works without any backend.
VITE_API_BASE=

# Password used ONLY in the localStorage dev fallback (when VITE_API_BASE is blank).
# In production the real password lives in the Worker, never in the frontend.
VITE_DEV_PASSWORD=scouts
